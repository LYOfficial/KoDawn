<h4 class="mb-3">你好，<%= project.dispatcher_label %> <%= current_user.username %></h4>
<p class="text-muted">所属项目：<%= project.name %></p>

<div class="list-group">
    <% if (project.activities && project.activities.length > 0) { %>
        <% project.activities.forEach(function(act) { %>
        <a href="/dispatcher/manage/<%= act.id %>" class="list-group-item list-group-item-action">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1"><%= act.name %></h5>
                <small>码: <%= act.code %></small>
            </div>
            <p class="mb-1">截止日期: <%= act.end_date || '无' %></p>
        </a>
        <% }); %>
    <% } %>
</div>
