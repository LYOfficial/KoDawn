<div class="card p-4">
    <h4 class="mb-3">确认预约信息</h4>
    <div class="alert alert-light border">
        <strong>时间：</strong> <%= formatDateTime(slot.start_time) %><br>
        <strong><%= activity.project.dispatcher_label %>：</strong><br>
        <% for (var k in slot_info) { %>
            <%= k %>: <%= slot_info[k] %><br>
        <% } %>
    </div>

    <form method="POST">
        <h5 class="mt-4 mb-3">请填写<%= activity.project.booker_label %>信息</h5>
        <% fields.forEach(function(field) { %>
        <div class="mb-3">
            <label class="form-label"><%= field %></label>
            <input type="text" name="field_<%= field %>" class="form-control" required>
        </div>
        <% }); %>
        
        <div class="alert alert-warning small">
            注：您的信息仅用于本次核对，<%= activity.project.dispatcher_label %>无法查看您的非必要隐私。
        </div>
        
        <div class="d-flex gap-2">
            <a href="javascript:history.back()" class="btn btn-secondary flex-fill">取消</a>
            <button type="submit" class="btn btn-primary flex-fill">确认预约</button>
        </div>
    </form>
</div>
