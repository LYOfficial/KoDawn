<div class="text-center mb-4">
    <h3><%= activity.name %></h3>
    <p class="text-muted">你好，<%= activity.project.booker_label %>，请选择时间</p>
    
    <% if (not_started) { %>
    <div class="alert alert-warning">
        活动尚未开始，开始时间：<%= formatDateTime(activity.start_time) %>
        <br>
        <span id="countdown" class="fw-bold text-danger"></span>
    </div>
    <% } else if (ended) { %>
    <div class="alert alert-secondary">
        活动已结束
    </div>
    <% } %>
</div>

<% if (grouped_slots && grouped_slots.length > 0) { %>
    <% grouped_slots.forEach(function(group_info) { %>
    <div class="mb-4">
        <h4 class="border-bottom pb-2 mb-3"><%= group_info.name %></h4>
        <div class="row">
            <% group_info.slots.forEach(function(s) { %>
            <div class="col-md-6">
                <!-- 如果没有名额 OR 放号员已满限额 OR 活动未开始/已结束，则变灰 -->
                <div class="card p-3 slot-card <%= s.disabled ? 'slot-full' : 'border-primary' %>" 
                     <% if (!s.disabled) { %>onclick="location.href='/book/<%= activity.code %>/slot/<%= s.id %>'"<% } %>>
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="mb-0"><%= formatDateTime(s.start_time, 'date') %></h5>
                            <div class="fw-bold text-primary"><%= formatDateTime(s.start_time, 'time') %> - <%= formatDateTime(s.end_time, 'time') %></div>
                        </div>
                        <div class="text-end">
                            <% if (not_started) { %>
                                 <span class="badge bg-warning text-dark">未开始</span>
                            <% } else if (ended) { %>
                                 <span class="badge bg-secondary">已结束</span>
                            <% } else if (s.dispatcherFull) { %>
                                 <span class="badge bg-secondary">放号员已满</span>
                            <% } else if (s.remain > 0) { %>
                                <span class="badge bg-success">余 <%= s.remain %></span>
                            <% } else { %>
                                <span class="badge bg-secondary">已抢光</span>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="mt-2 text-muted small border-top pt-2">
                        <%= activity.project.dispatcher_label %>:
                        <% for (var k in s.data) { %>
                            <div><strong><%= k %>:</strong> <%= s.data[k] %></div>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
    </div>
    <% }); %>
<% } else { %>
<div class="text-center text-muted mt-5">
    <p>暂无号源，请稍后再来。</p>
</div>
<% } %>

<% if (not_started && activity.start_time) { %>
<script>
function updateCountdown() {
    var now = new Date().getTime();
    var startTime = new Date("<%= new Date(activity.start_time).toISOString() %>").getTime();
    var distance = startTime - now;

    if (distance < 0) {
        document.getElementById("countdown").innerHTML = "活动已开始，请刷新页面！";
        return;
    }

    var days = Math.floor(distance / (1000 * 60 * 60 * 24));
    var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    var seconds = Math.floor((distance % (1000 * 60)) / 1000);

    document.getElementById("countdown").innerHTML = "倒计时: " + days + "天 " + hours + "时 " + minutes + "分 " + seconds + "秒 ";
}
setInterval(updateCountdown, 1000);
updateCountdown();
</script>
<% } %>
