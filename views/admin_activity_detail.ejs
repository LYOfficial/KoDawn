<nav aria-label="breadcrumb">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/admin">首页</a></li>
    <li class="breadcrumb-item"><a href="/admin/project/<%= activity.project.id %>">项目管理</a></li>
    <li class="breadcrumb-item active">数据详情</li>
  </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><%= activity.name %> - 数据总览</h3>
    <span class="badge bg-primary fs-6"><%= activity.code %></span>
</div>

<div class="table-responsive">
    <table class="table table-bordered table-striped bg-white">
        <thead class="table-dark">
            <tr>
                <th>时间段</th>
                <th><%= activity.project.dispatcher_label %></th>
                <th>放号信息</th>
                <th>进度</th>
                <th><%= activity.project.booker_label %>详情 (含取号码)</th>
            </tr>
        </thead>
        <tbody>
            <% slots.forEach(function(s) { %>
            <tr>
                <td style="min-width: 120px;">
                    <%= formatDateTime(s.start_time, 'date') %><br>
                    <%= formatDateTime(s.start_time, 'time') %> - <%= formatDateTime(s.end_time, 'time') %>
                </td>
                <td><%= s.dispatcher.username %></td>
                <td>
                    <% for (var k in s.data) { %><div class="small"><strong><%= k %>:</strong> <%= s.data[k] %></div><% } %>
                </td>
                <td>
                    <span class="badge <%= s.current_count >= s.capacity ? 'bg-secondary' : 'bg-success' %>">
                        <%= s.current_count %> / <%= s.capacity %>
                    </span>
                </td>
                <td>
                    <% if (s.bookings && s.bookings.length > 0) { %>
                        <ul class="list-unstyled mb-0">
                        <% s.bookings.forEach(function(b) { %>
                            <li class="mb-2 border-bottom pb-1">
                                <span class="badge bg-warning text-dark"><%= b.booking_code %></span>
                                <small class="text-muted ms-2"><%= formatDateTime(b.created_at, 'monthday') %> <%= formatDateTime(b.created_at, 'time') %></small><br>
                                <% for (var k in b.data) { %>
                                    <span class="me-2"><strong><%= k %>:</strong> <%= b.data[k] %></span>
                                <% } %>
                            </li>
                        <% }); %>
                        </ul>
                    <% } else { %>
                        <span class="text-muted small">暂无</span>
                    <% } %>
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>
</div>

<% if (!slots || slots.length === 0) { %>
<div class="text-center p-5 text-muted">暂无放号数据</div>
<% } %>
